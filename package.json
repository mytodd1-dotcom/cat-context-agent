{
  "name": "cat-context-agent",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "demo": "node scripts/cat-context-demo.mjs",
    "datahub:bridge": "node scripts/datahub-local-bridge.mjs",
    "datahub:payload": "node scripts/datahub-payload-preview.mjs",
    "datahub:runbook": "node scripts/live-datahub-runbook.mjs",
    "datahub:doctor": "node scripts/datahub-readiness-doctor.mjs",
    "datahub:roundtrip": "node scripts/datahub-live-roundtrip.mjs",
    "datahub:checklist": "node scripts/datahub-integration-checklist.mjs",
    "datahub:audit": "node scripts/datahub-claim-audit.mjs",
    "datahub:mcp": "node scripts/datahub-mcp-handoff.mjs",
    "mcp:smoke": "node scripts/mcp-adapter-smoke.mjs",
    "submission:honesty": "node scripts/submission-honesty-audit.mjs",
    "decision:trace": "node scripts/decision-trace.mjs",
    "lineage:map": "node scripts/lineage-decision-map.mjs",
    "policy:matrix": "node scripts/safety-policy-matrix.mjs",
    "context:read": "node scripts/cat-context-provider.mjs",
    "context:contracts": "node scripts/context-tool-contracts.mjs",
    "judge:pack": "node scripts/judge-evidence-pack.mjs",
    "judge:quick": "node scripts/judge-quick-card.mjs",
    "judge:rubric": "node scripts/judge-rubric-matrix.mjs",
    "judge:walkthrough": "node scripts/judge-walkthrough.mjs",
    "judge:faq": "node scripts/judge-faq.mjs",
    "submission:verify": "node scripts/verify-submission.mjs",
    "artifacts:validate": "node scripts/validate-artifacts.mjs",
    "evidence:reproduce": "node scripts/reproduce-evidence.mjs",
    "judge:brief": "node scripts/judge-scoring-brief.mjs",
    "devpost:copy": "node scripts/devpost-submission-copy.mjs",
    "submission:index": "node scripts/submission-index.mjs",
    "demo:guide": "node scripts/demo-video-guide.mjs",
    "ci:local": "npm ci --dry-run && npm run context:contracts && npm run datahub:payload && npm run datahub:runbook && npm run datahub:doctor && npm run datahub:roundtrip && npm run datahub:checklist && npm run datahub:audit && npm run datahub:mcp && npm run mcp:smoke && npm run devpost:copy && npm run submission:honesty && npm run decision:trace && npm run lineage:map && npm run policy:matrix && npm run submission:verify && npm run judge:walkthrough && npm run judge:faq && npm run judge:quick && npm run judge:rubric && npm run artifacts:validate && npm run judge:brief && npm run submission:index && npm run demo:guide && npm test",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
